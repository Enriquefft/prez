{
  "name": "@enriquefft/prez",
  "publishConfig": {
    "access": "public"
  },
  "version": "1.0.0",
  "description": "Zero-opinion presentation engine for AI. You bring the content, Claude brings the design.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js",
      "require": "./dist/node.cjs"
    }
  },
  "bin": {
    "prez": "./dist/cli/init.js",
    "prez-image": "./dist/cli/image.js",
    "prez-export": "./dist/cli/export.js",
    "prez-validate": "./dist/cli/validate.js"
  },
  "files": [
    "dist",
    "template"
  ],
  "scripts": {
    "prepare": "tsup",
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome check",
    "lint:fix": "biome check --fix",
    "format": "biome format --write",
    "test": "bun test"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@happy-dom/global-registrator": "^20.8.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.0",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "happy-dom": "^20.8.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "keywords": [
    "presentation",
    "slides",
    "deck",
    "react",
    "ai",
    "claude",
    "vite"
  ],
  "engines": {
    "node": ">=22"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Enriquefft/prez"
  },
  "homepage": "https://github.com/Enriquefft/prez",
  "bugs": "https://github.com/Enriquefft/prez/issues",
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@resvg/resvg-js": "^2.6.2",
    "pngjs": "^7.0.0",
    "pptxgenjs": "^3.12.0"
  }
}
